generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Now page content ─────────────────────────────────────────
model NowEntry {
  id        String   @id @default(cuid())
  section   String   // "building" | "learning" | "reading"
  content   String   @db.Text
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ── Bookshelf ─────────────────────────────────────────────────
model Book {
  id        String   @id @default(cuid())
  title     String
  author    String
  coverUrl  String?
  link      String?
  status    String   @default("reading") // "reading" | "read" | "want"
  rating    Int?     // 1-5, null if unread
  notes     String?  @db.Text
  finishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Contact messages ──────────────────────────────────────────
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── Analytics (simple view counter) ──────────────────────────
model PageView {
  id        String   @id @default(cuid())
  slug      String
  section   String   // "writing" | "garden" | "page"
  month     String   // "YYYY-MM"
  count     Int      @default(1)
  updatedAt DateTime @updatedAt

  @@unique([slug, month])
}

// ── Projects ──────────────────────────────────────────────
model Project {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  summary     String    @db.Text
  description String?   @db.Text
  coverUrl    String?
  liveUrl     String?
  githubUrl   String?
  techStack   String[]
  category    String    @default("web") // "web" | "data" | "oss" | "other"
  featured    Boolean   @default(false)
  order       Int       @default(0)
  published   Boolean   @default(true)
  builtAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Uses Items ─────────────────────────────────────────────
model UsesItem {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  category    String   // "hardware" | "terminal" | "stack" | "apps" | "reading"
  url         String?
  imageUrl    String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Gallery Albums ─────────────────────────────────────────
model GalleryAlbum {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String?        @db.Text
  coverUrl    String?
  emoji       String?        // e.g. "🌍" optional decorative emoji
  order       Int            @default(0)
  published   Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  media       GalleryMedia[]
}

// ── Gallery Media Items ────────────────────────────────────
model GalleryMedia {
  id           String       @id @default(cuid())
  albumId      String
  album        GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  type         String       // "image" | "video"
  url          String       // Cloudinary delivery URL
  thumbnailUrl String?      // Low-res placeholder or video poster
  publicId     String?      // Cloudinary public_id for deletion
  caption      String?
  location     String?
  takenAt      DateTime?
  width        Int?
  height       Int?
  order        Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ── Bookmarks / Link Stash ─────────────────────────────────
model Bookmark {
  id          String   @id @default(cuid())
  url         String
  title       String
  description String?
  note        String?  @db.Text
  tags        String[]
  via         String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Guestbook ──────────────────────────────────────────────
model GuestbookEntry {
  id        String   @id @default(cuid())
  name      String
  message   String   @db.Text
  email     String?  // never shown publicly
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── Timeline / Journey ─────────────────────────────────────
model TimelineEntry {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  category    String   // "career" | "life" | "travel" | "education" | "project"
  date        DateTime
  icon        String?  // emoji
  linkUrl     String?
  linkLabel   String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Post Reactions ──────────────────────────────────────────
model PostReaction {
  id        String   @id @default(cuid())
  slug      String
  type      String   // "learned" | "bookmarked" | "thinking"
  count     Int      @default(1)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([slug, type])
}

// ── Email Digest Subscribers ─────────────────────────────────
model DigestSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Posts (Writing / Garden) ─────────────────────────────────
model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  content     String   @db.Text
  type        String   @default("writing") // "writing" | "garden"
  category    String?  // "essay" | "tutorial" | "til"
  stage       String?  // "seedling" | "budding" | "evergreen"
  tags        String[]
  published   Boolean  @default(true)
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
